# Copy to `.env`. Loaded by main.py at startup; real environment variables win.
#
# Env holds what varies per machine: where files live, which host to talk to,
# where an external tool is. Behaviour (templates, concurrency, retries,
# filters, timers) belongs in data/config.json.
#
#   precedence:  environment  >  data/config.json  >  built-in defaults

# ---- Proxy (standard names; requests reads these automatically) ----
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=http://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1

# ---- Where things live ----
# PAWCHIVE_DATA_DIR says where config.json itself is, so it can only be set
# here -- never in config.json.
# PAWCHIVE_DATA_DIR=data
# PAWCHIVE_CACHE_DIR=cache
# PAWCHIVE_LOGS_DIR=logs
# PAWCHIVE_DOWNLOAD_DIR=F:/Download/kemono

# ---- Endpoints (Pawchive has changed domains before: .st -> .pw) ----
# PAWCHIVE_API_BASE=https://pawchive.pw/api/v1
# PAWCHIVE_FILE_BASE=https://file.pawchive.pw

# ---- Misc ----
# PAWCHIVE_USER_AGENT=Mozilla/5.0 ...
# PAWCHIVE_CLOUD_DIR=cloud
# PAWCHIVE_GDOWN_BIN=gdown
